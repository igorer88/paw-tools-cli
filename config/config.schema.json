{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "app": {
      "type": "object",
      "properties": {
        "environment": {
          "type": "string",
          "enum": ["development", "production", "test"],
          "default": "development",
          "description": "Application environment"
        },
        "debug": {
          "type": "boolean",
          "default": false,
          "description": "Enable debug mode"
        },
        "secretKey": {
          "type": "string",
          "description": "App secret key for authentication"
        },
        "loggerLevels": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": ["log", "error", "warn", "debug", "verbose", "fatal"],
          "description": "Logger levels"
        }
      },
      "required": ["environment"]
    }
  }
}
