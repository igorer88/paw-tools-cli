# =============================================================================
# CLI Configuration
# These environment variables override values from config/config.json
# =============================================================================

# Environment (development, production, test)
NODE_ENV=development

# Enable debug mode (true/false)
DEBUG=false

# App Secret Key (optional, min 32 chars if provided)
# APP_SECRET_KEY=

# App Logger Levels (comma-separated)
APP_LOGGER_LEVELS=log,error,warn,debug,verbose,fatal
