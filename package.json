{
  "name": "paw-tools-cli",
  "version": "0.1.0",
  "description": "CLI tools for paw ecosystem",
  "author": "Igor Escalona",
  "private": true,
  "license": "MIT",
  "bin": {
    "paw-tools": "dist/main.js"
  },
  "engines": {
    "node": ">=24.x",
    "pnpm": ">=10.x"
  },
  "keywords": [
    "typescript",
    "nestjs",
    "cli",
    "tools"
  ],
  "scripts": {
    "setup:agents": "node ./config/scripts/sync-agents.mjs",
    "build": "nest build",
    "cli": "node dist/main",
    "cli:dev": "ts-node -r tsconfig-paths/register src/main.ts",
    "lint": "biome check --write --no-errors-on-unmatched",
    "format": "biome format --write",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "rimraf coverage && jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:e2e:cov": "rimraf coverage-e2e && jest --config ./test/jest-e2e.json --coverage",
    "test:all:cov": "pnpm test:cov && pnpm test:e2e:cov",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "prepare": "husky"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@nestjs/common": "^11.1.16",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.16",
    "@nestjs/mapped-types": "2.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "consola": "^3.4.2",
    "joi": "^18.1.1",
    "nest-commander": "^3.3.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@commitlint/config-conventional": "^20.5.0",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.16",
    "@swc/cli": "^0.8.0",
    "@swc/core": "^1.15.21",
    "@types/hapi__joi": "^17.1.15",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "commitlint": "^20.5.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0",
    "rimraf": "^6.1.3",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "yaml": "^2.8.3"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "biome check --write --no-errors-on-unmatched",
      "biome format --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "file-type": ">=21.3.2",
      "tar": ">=7.5.11",
      "lodash": ">=4.18.0",
      "picomatch": ">=4.0.4",
      "path-to-regexp": ">=8.4.0",
      "brace-expansion": ">=5.0.5",
      "minimatch": ">=3.1.5 <4.0.0",
      "handlebars": ">=4.7.9",
      "yaml": ">=2.8.3",
      "ajv": ">=8.18.0"
    }
  }
}
