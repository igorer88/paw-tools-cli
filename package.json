{
  "name": "paw-tools-cli",
  "version": "0.1.0",
  "description": "CLI tools for paw ecosystem",
  "author": "Igor Escalona",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=24.x",
    "pnpm": ">=10.x"
  },
  "keywords": [
    "typescript",
    "nestjs",
    "cli",
    "tools"
  ],
  "scripts": {
    "setup:agents": "node ./config/scripts/sync-agents.mjs",
    "generate:secret": "node ./config/scripts/generate-secret-key.mjs",
    "build": "nest build",
    "cli": "node dist/main",
    "cli:dev": "ts-node src/main.ts",
    "lint": "eslint --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "rimraf coverage && jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "prepare": "husky"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.16",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.16",
    "@nestjs/mapped-types": "2.1.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "joi": "^18.0.2",
    "nest-commander": "^3.3.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/compat": "^2.0.3",
    "@helljs/eslint-import-resolver-x": "^1.1.0",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.16",
    "@swc/cli": "^0.8.0",
    "@swc/core": "^1.15.18",
    "@types/hapi__joi": "^17.1.15",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "commitlint": "^20.5.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-oxc": "^0.15.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  },
  "pnpm": {
    "overrides": {
      "file-type": ">=21.3.2"
    }
  }
}
